{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CapstoneApplyServiceScoped",
      "Effect": "Allow",
      "Action": [
        "kms:*",
        "s3:*",
        "dynamodb:*",
        "lambda:*",
        "ec2:*",
        "apigateway:*",
        "logs:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CapstoneApplyIAMScoped",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:PassRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:ListInstanceProfilesForRole",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy"
      ],
      "Resource": "arn:aws:iam::254053128942:role/acme-health-intake-*"
    }
  ]
}