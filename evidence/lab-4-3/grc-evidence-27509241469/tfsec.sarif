{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0-rtm.5.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "informationUri": "https://github.com/aquasecurity/defsec",
          "name": "defsec",
          "rules": [
            {
              "id": "aws-s3-enable-versioning",
              "shortDescription": {
                "text": "S3 Data should be versioned"
              },
              "helpUri": "https://aquasecurity.github.io/tfsec/v1.28.14/checks/aws/s3/enable-versioning/"
            },
            {
              "id": "aws-s3-encryption-customer-key",
              "shortDescription": {
                "text": "S3 encryption should use Customer Managed Keys"
              },
              "helpUri": "https://aquasecurity.github.io/tfsec/v1.28.14/checks/aws/s3/encryption-customer-key/"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "aws-s3-enable-versioning",
          "ruleIndex": 0,
          "level": "warning",
          "message": {
            "text": "Bucket does not have versioning enabled"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.tf"
                },
                "region": {
                  "startLine": 82,
                  "endLine": 84
                }
              }
            }
          ]
        },
        {
          "ruleId": "aws-s3-encryption-customer-key",
          "ruleIndex": 1,
          "level": "error",
          "message": {
            "text": "Bucket does not encrypt data with a customer managed key."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.tf"
                },
                "region": {
                  "startLine": 44,
                  "endLine": 60
                }
              }
            }
          ]
        }
      ]
    }
  ]
}